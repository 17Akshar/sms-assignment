# Server
PORT=5000
NODE_ENV=development

# PostgreSQL connection (local)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=student_management

# SSL config (set to "true" for hosted databases like Aiven, Supabase, Neon, etc.)
# PGSSL=true
# For Vercel: paste the CA cert content directly (multiline supported)
# PGSSLCA=-----BEGIN CERTIFICATE-----\nMIIF...\n-----END CERTIFICATE-----

# Alternatively, a single connection string (overrides the PG* vars above if set)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/student_management

# CORS - comma separated list of allowed origins
CLIENT_ORIGIN=http://localhost:5173

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5
